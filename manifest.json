{
  "manifest_version": 3,
  "name": "ViettelPost AutoPilot",
  "version": "3.0",
  "description": "Hệ thống tự động hóa vận hành ViettelPost (Sửa Giờ, Đánh Giá 5★, Kiểm Kê Tồn, Kiểm Tra Đơn, Phân Công Tuyến)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "*://*.viettelpost.vn/*",
    "*://*.viettelpost.com.vn/*",
    "*://evtp2.viettelpost.vn/*",
    "http://localhost/*"
  ],
  "icons": {
    "16":  "assets/icons/icon16.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "VTP Tool – Mở bảng điều khiển"
  },
  "side_panel": {
    "default_path": "src/ui/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}